<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Polyphony.SchemaExporter: tiny console app that reads
    `Polyphony.VerbOutputSchemaCatalog.Json` (generated by
    Polyphony.SchemaGenerator into the Polyphony assembly at compile
    time) and writes it to a file path passed via the &quot;out&quot; flag.

    Building this project transitively builds Polyphony, then runs
    this exe via the AfterBuild target below to drop the JSON
    artifact at artifacts/verb-output-schemas.json.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Polyphony.SchemaExporter</RootNamespace>
    <AssemblyName>polyphony-schema-export</AssemblyName>
    <!-- AOT-clean concern doesn't apply here; this is build-time tooling. -->
    <PublishAot>false</PublishAot>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Polyphony\Polyphony.csproj" />
  </ItemGroup>

  <!--
    Post-build: run the exporter exe to write the verb output schema
    catalog (compile-time-embedded into Polyphony.dll by the generator)
    out to artifacts/verb-output-schemas.json. Skip when
    SkipSchemaExport=true (e.g. unit-test inner loop).
  -->
  <Target Name="ExportVerbOutputSchemas"
          AfterTargets="Build"
          Condition="'$(SkipSchemaExport)' != 'true'">
    <Exec Command="dotnet &quot;$(TargetPath)&quot; --out &quot;$(MSBuildThisFileDirectory)..\..\artifacts\verb-output-schemas.json&quot;"
          ContinueOnError="false" />
  </Target>

</Project>
